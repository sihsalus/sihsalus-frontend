{
  "name": "@sihsalus/esm-interconsultas-app",
  "version": "1.0.0-alpha",
  "description": "Módulo de interconsultas (NTS 030/097/139 — MINSA) para SIHSALUS - OpenMRS O3",
  "browser": "dist/sihsalus-esm-interconsultas-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "yarn serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage --passWithNoTests",
    "typescript": "tsc --noEmit",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus",
    "interconsultas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm-modules/issues"
  },
  "dependencies": {
    "@sihsalus/esm-rbac": "workspace:*"
  },
  "peerDependencies": {
    "@carbon/colors": "11.x",
    "@carbon/layout": "11.x",
    "@carbon/react": "1.x",
    "@carbon/styles": "1.x",
    "@openmrs/esm-framework": "*",
    "@openmrs/esm-patient-common-lib": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@rspack/cli": "1.7.11",
    "@rspack/core": "1.7.11",
    "openmrs": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
