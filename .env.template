# ─── SIH Salus Frontend — Variables de entorno ────────────────────────────────
# Copia este archivo a .env y ajusta los valores a tu entorno:
#   cp .env.template .env

# URL del backend OpenMRS al que se redirigen las peticiones de API.
# Usado por el dev server (openmrs develop --backend) y por el script de ensamble.
SIHSALUS_BACKEND_URL=https://gidis-hsc-dev.inf.pucp.edu.pe

# En entornos con certificado auto firmado (por ejemplo QLTY/DEV internos),
# el dev server lo permite por defecto. Usa false para forzar validación TLS estricta.
SIHSALUS_ALLOW_SELF_SIGNED_TLS=true

# Modo de autenticación: 'openmrs' (básico) o 'keycloak' (OIDC/SSO)
SIHSALUS_AUTH_MODE=openmrs

# URL base de FHIR R4 del servidor backend
SIHSALUS_FHIR_BASE=https://gidis-hsc-dev.inf.pucp.edu.pe/openmrs/ws/fhir2/R4

# URL publica absoluta del SPA, usada para metatags Open Graph/Twitter.
# Ejemplo: https://gidis-hsc-qlty.inf.pucp.edu.pe/openmrs/spa
SIHSALUS_PUBLIC_SPA_URL=https://gidis-hsc-dev.inf.pucp.edu.pe/openmrs/spa

# Límite por IP para las rutas de desarrollo que leen archivos de configuración
# locales. Los valores deben ser enteros positivos; cero o valores inválidos
# mantienen los defaults seguros.
# SIHSALUS_DEV_LOCAL_CONFIG_RATE_LIMIT_WINDOW_MS=60000
# SIHSALUS_DEV_LOCAL_CONFIG_RATE_LIMIT_MAX=300

# ─── E2E Tests (Playwright) ───────────────────────────────────────────────────
# Base URL para tests end-to-end. Puede apuntar al contexto OpenMRS o al SPA;
# ambos formatos se normalizan internamente:
#   http://localhost:8080/openmrs
#   http://localhost:8080/openmrs/spa
E2E_BASE_URL=http://localhost:8080/openmrs/spa

# Base URL de la API OpenMRS para autenticación/setup de tests. Si se omite,
# se deriva de E2E_BASE_URL removiendo /spa cuando aplique.
E2E_API_BASE_URL=http://localhost:8080/openmrs

# Útil para specs públicos/pre-login, como accesibilidad del login, que no
# necesitan sesión de backend.
E2E_SKIP_AUTH=false

# Usa true cuando ya levantaste `yarn start` manualmente y no quieres que
# Playwright intente arrancar otro webServer.
E2E_DISABLE_WEB_SERVER=false

# Credenciales del usuario admin para autenticación en tests
E2E_USER_ADMIN_USERNAME=admin
E2E_USER_ADMIN_PASSWORD=Admin123

# UUID de la location por defecto para login en tests
E2E_LOGIN_DEFAULT_LOCATION_UUID=44c3efb0-2583-4c80-a79e-1f756a03c0a1
