{
  "name": "@sihsalus/esm-form-builder-app",
  "version": "1.0.0-alpha",
  "license": "MPL-2.0",
  "description": "Form Builder for O3",
  "browser": "dist/openmrs-esm-form-builder-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "typescript": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "test-e2e": "yarn --cwd ../../.. playwright test --config e2e/form-builder/playwright.config.ts",
    "verify": "turbo run lint typescript coverage --color",
    "coverage": "vitest run --coverage --passWithNoTests",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.modal.tsx' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends",
    "form builder"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-form-builder.git"
  },
  "homepage": "https://github.com/openmrs/openmrs-esm-form-builder#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-form-builder/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "@sihsalus/esm-form-engine-lib": "workspace:*",
    "@sihsalus/esm-rbac": "workspace:*",
    "ajv": "^8.17.1",
    "dotenv": "^16.4.5",
    "file-loader": "^6.2.0",
    "fuzzy": "^0.1.3",
    "lodash-es": "^4.17.21",
    "react-ace": "^11.0.1",
    "react-markdown": "^9.0.1",
    "react-mde": "^11.5.0",
    "sass": "^1.67.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "rxjs": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^6.0.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "@playwright/test": "^1.50.1",
    "@swc/cli": "^0.1.65",
    "@swc/core": "1.15.21",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "openmrs": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.0.13",
    "react-i18next": "^16.0.0",
    "rxjs": "^6.6.7",
    "turbo": "^2.9.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{css,js,json,ts,tsx}": "node ../../tooling/scripts/run-biome.js check --write",
    "*.scss": "prettier --write"
  },
  "packageManager": "yarn@4.10.3"
}
