{
  "name": "@sihsalus/esm-odontologia-app",
  "version": "1.0.0-alpha",
  "license": "MPL-2.0",
  "description": "Microfrontend de odontologia para O3",
  "browser": "dist/openmrs-esm-odontologia-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "typescript": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "extract-translations": "i18next 'src/**/*.tsx' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends",
    "odontologia"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "rxjs": "6.x"
  },
  "dependencies": {
    "@carbon/react": "^1.92.1",
    "@carbon/styles": "^1.102.0",
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@sihsalus/esm-rbac": "workspace:*",
    "konva": "^9.3.18",
    "react-konva": "^19.0.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "openmrs": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "^4.1.0"
  }
}
