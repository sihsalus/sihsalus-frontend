{
  "name": "@sihsalus/esm-template-app",
  "version": "1.0.0-alpha",
  "license": "MPL-2.0",
  "description": "Template for new SIHSALUS OpenMRS microfrontends",
  "browser": "dist/sihsalus-esm-template-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "yarn serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "typescript": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage --passWithNoTests",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "files": [
    "dist",
    "src",
    "translations"
  ],
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sihsalus/esm-rbac": "workspace:*"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "*",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@rspack/cli": "1.7.11",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "openmrs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.14.1",
    "rxjs": "^6.6.7",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  }
}
