{
  "name": "@sihsalus/esm-ficha-familiar-app",
  "version": "1.0.0-alpha",
  "description": "Módulo de Ficha Familiar (vínculos del paciente) para el contexto de salud peruano - OpenMRS O3",
  "browser": "dist/sihsalus-esm-ficha-familiar-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "yarn serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage --passWithNoTests",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm-modules/issues"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.1",
    "@sihsalus/esm-sihsalus-shared": "workspace:*",
    "lodash-es": "^4.17.21",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "*",
    "@openmrs/esm-patient-common-lib": "*",
    "react": "18.x",
    "react-hook-form": "^7.56.1",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@carbon/colors": "^11.48.0",
    "@carbon/layout": "^11.50.0",
    "@carbon/react": "^1.102.0",
    "@carbon/styles": "^1.102.0",
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@rspack/cli": "1.7.11",
    "@rspack/core": "1.7.11",
    "dayjs": "^1.11.13",
    "i18next": "^25.7.2",
    "openmrs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.1",
    "react-i18next": "^16.0.0",
    "react-is": "^19.1.1",
    "react-router-dom": "^6.30.2",
    "rxjs": "^6.6.7",
    "sass": "^1.98.0",
    "single-spa": "^6.0.3",
    "swr": "^2.4.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
