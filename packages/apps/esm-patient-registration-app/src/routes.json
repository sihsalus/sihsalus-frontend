{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": ">=1.2",
    "webservices.rest": ">=2.24.0"
  },
  "pages": [
    {
      "component": "root",
      "route": "patient-registration",
      "online": true,
      "offline": true
    },
    {
      "component": "editPatient",
      "routeRegex": "patient\\/([a-zA-Z0-9\\-]+)\\/edit",
      "online": true,
      "offline": true
    },
    {
      "component": "bulkPatientImport",
      "route": "patient-import",
      "online": true,
      "offline": false
    }
  ],
  "extensions": [
    {
      "component": "addPatientLink",
      "name": "add-patient-action",
      "slot": "top-nav-actions-slot",
      "privileges": "app:opciones.registrarPaciente",
      "online": true,
      "offline": true
    },
    {
      "component": "patientPhotoExtension",
      "name": "patient-photo-widget",
      "slot": "patient-photo-slot",
      "online": true,
      "offline": true
    },
    {
      "component": "editPatientDetailsButton",
      "name": "edit-patient-details-button",
      "slot": "patient-actions-slot",
      "privileges": "app:opciones.registrarPaciente",
      "online": true,
      "offline": true
    },
    {
      "component": "editPatientDetailsButton",
      "name": "edit-patient-details-button",
      "slot": "patient-search-actions-slot",
      "privileges": "app:opciones.registrarPaciente",
      "online": true,
      "offline": true
    },
    {
      "component": "bulkPatientImportAdminCardLink",
      "name": "system-administration-patient-import-card-link",
      "slot": "system-admin-page-card-link-slot",
      "privileges": "Manage Patients",
      "online": true,
      "offline": false
    }
  ],
  "modals": [
    {
      "name": "cancel-patient-edit-modal",
      "component": "cancelPatientEditModal"
    },
    {
      "name": "delete-identifier-confirmation-modal",
      "component": "deleteIdentifierConfirmationModal"
    }
  ]
}
