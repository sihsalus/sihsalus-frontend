{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "stripInternal": true,
    "declaration": true,
    "incremental": false,
    "noEmit": false,
    "rootDir": "src"
  },
  "extends": "./tsconfig.json",
  "exclude": ["**/*.test.*", "**/setup-tests.ts", "**/__mocks__/*", "**/mock.tsx", "**/setup-tests.*"]
}
