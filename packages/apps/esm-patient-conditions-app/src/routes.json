{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": ">=2.8.0",
    "webservices.rest": ">=2.2.0"
  },
  "extensions": [
    {
      "name": "conditions-overview-widget",
      "slot": "patient-chart-summary-dashboard-slot",
      "component": "conditionsOverview",
      "privileges": "app:hoja.clinica.condiciones",
      "order": 3,
      "meta": {
        "fullWidth": false
      }
    },
    {
      "name": "active-problems-overview-widget",
      "slot": "patient-chart-summary-dashboard-slot",
      "component": "activeProblemsOverview",
      "privileges": "app:hoja.clinica.condiciones",
      "order": 4,
      "meta": {
        "fullWidth": false
      }
    },
    {
      "name": "past-diagnoses-overview-widget",
      "slot": "patient-chart-summary-dashboard-slot",
      "component": "pastDiagnosesOverview",
      "privileges": "app:hoja.clinica.condiciones",
      "order": 5,
      "meta": {
        "fullWidth": false
      }
    },
    {
      "name": "conditions-details-widget",
      "slot": "patient-chart-conditions-dashboard-slot",
      "component": "conditionsDetailedSummary",
      "privileges": "app:hoja.clinica.condiciones",
      "meta": {
        "fullWidth": false
      }
    },
    {
      "name": "conditions-summary-dashboard",
      "component": "conditionsDashboardLink",
      "slot": "patient-chart-dashboard-slot",
      "privileges": "app:hoja.clinica.condiciones",
      "order": 7,
      "meta": {
        "slot": "patient-chart-conditions-dashboard-slot",
        "path": "Antecedentes"
      }
    },
    {
      "name": "conditions-widget",
      "component": "conditionsWidget"
    },
    {
      "name": "condition-delete-confirmation-dialog",
      "component": "conditionDeleteConfirmationDialog",
      "privileges": "app:hoja.clinica.condiciones.editar"
    }
  ],
  "workspaces2": [
    {
      "name": "conditions-form-workspace",
      "component": "conditionsFormWorkspace",
      "window": "conditions-form-window",
      "privileges": "app:hoja.clinica.condiciones.editar"
    },
    {
      "name": "active-problem-form-workspace",
      "component": "conditionsFormWorkspace",
      "window": "conditions-form-window",
      "privileges": "app:hoja.clinica.condiciones.editar"
    },
    {
      "name": "past-diagnosis-form-workspace",
      "component": "conditionsFormWorkspace",
      "window": "conditions-form-window",
      "privileges": "app:hoja.clinica.condiciones.editar"
    }
  ],
  "workspaceWindows2": [
    {
      "name": "conditions-form-window",
      "group": "patient-chart"
    }
  ]
}
