{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": ">=1.2",
    "webservices.rest": ">=2.2.0"
  },
  "pages": [
    {
      "component": "root",
      "routeRegex": "forms",
      "online": true,
      "offline": true
    }
  ],
  "extensions": [
    {
      "name": "forms-app-menu-item",
      "slot": "app-menu-item-slot",
      "component": "formsAppMenuItem",
      "order": 70,
      "online": true,
      "offline": true
    }
  ]
}
