# ─── SIH Salus Frontend — Variables de entorno ────────────────────────────────
# Copia este archivo a .env y ajusta los valores a tu entorno:
#   cp .env.example .env

# URL del backend OpenMRS al que se redirigen las peticiones de API.
# Usado por el dev server (openmrs develop --backend) y por el script de ensamble.
SIHSALUS_BACKEND_URL=http://gidis-hsc-dev.inf.pucp.edu.pe

# Modo de autenticación: 'openmrs' (básico) o 'keycloak' (OIDC/SSO)
SIHSALUS_AUTH_MODE=openmrs

# URL base de FHIR R4 del servidor backend
SIHSALUS_FHIR_BASE=http://gidis-hsc-dev.inf.pucp.edu.pe/openmrs/ws/fhir2/R4

# ─── E2E Tests (Playwright) ───────────────────────────────────────────────────
# Base URL del SPA para los tests end-to-end
E2E_BASE_URL=http://localhost:8080/openmrs/spa

# Base URL de la API OpenMRS para autenticación/setup de tests. Si se omite,
# se deriva de E2E_BASE_URL removiendo /spa.
E2E_API_BASE_URL=http://localhost:8080/openmrs

# Útil para specs públicos/pre-login, como accesibilidad del login, que no
# necesitan sesión de backend.
E2E_SKIP_AUTH=false

# Credenciales del usuario admin para autenticación en tests
E2E_USER_ADMIN_USERNAME=admin
E2E_USER_ADMIN_PASSWORD=Admin123

# UUID de la location por defecto para login en tests
E2E_LOGIN_DEFAULT_LOCATION_UUID=44c3efb0-2583-4c80-a79e-1f756a03c0a1
