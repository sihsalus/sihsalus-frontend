{
  "name": "@sihsalus/esm-billing-app",
  "version": "1.0.0-alpha",
  "description": "O3 frontend module for handling billing concerns in healthcare settings",
  "browser": "dist/openmrs-esm-billing-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "homepage": "https://github.com/openmrs/openmrs-esm-billing-app#readme",
  "scripts": {
    "start": "openmrs develop",
    "analyze": "rspack --mode=production --env analyze=true",
    "build": "rspack --mode=production",
    "coverage": "vitest run --coverage --passWithNoTests",
    "debug": "yarn serve",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "prettier": "node ../../tooling/scripts/run-biome.js format --write src e2e",
    "serve": "rspack serve --mode=development",
    "test-e2e": "yarn --cwd ../../.. playwright test --config e2e/billing/playwright.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "typescript": "tsc",
    "verify": "turbo lint && turbo typescript && turbo test --color --concurrency=5"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-billing-app#readme"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-billing-app/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "@hookform/resolvers": "^3.3.4",
    "@sihsalus/esm-rbac": "workspace:*",
    "classnames": "^2.5.1",
    "fuzzy": "^0.1.3",
    "lodash-es": "^4.17.21",
    "react-hook-form": "^7.49.3",
    "react-to-print": "^3.1.1",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "@openmrs/esm-patient-common-lib": "*",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "rxjs": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@playwright/test": "^1.53.2",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.21",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "babel-preset-minify": "^0.5.2",
    "concurrently": "^8.2.2",
    "d3-selection": "^3.0.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.1",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "lodash": "^4.18.1",
    "openmrs": "*",
    "pinst": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.21.3",
    "rxjs": "^6.6.7",
    "sass": "^1.70.0",
    "swr": "^2.2.4",
    "turbo": "^2.9.18",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "yarn@4.10.3"
}
