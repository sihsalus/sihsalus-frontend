{
  "name": "@sihsalus/esm-dyaku-app",
  "version": "1.0.0-alpha",
  "description": "Main openmrs O3 SIHSALUS microfrontend",
  "browser": "dist/sihsalus-esm-dyaku-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "yarn serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage --passWithNoTests",
    "typescript": "tsc --noEmit",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm-modules#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm-modules.git"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm-modules/issues"
  },
  "peerDependencies": {
    "@carbon/colors": "1.x",
    "@carbon/layout": "1.x",
    "@carbon/react": "1.x",
    "@carbon/styles": "1.x",
    "@openmrs/esm-framework": "*",
    "@openmrs/esm-patient-common-lib": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-is": "19.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@rspack/cli": "1.7.11",
    "openmrs": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  }
}
