      "privileges": "app:service-queues"
    },
    {
      "name": "service-queues-visit-notes-workspace",
      "component": "@sihsalus/esm-patient-notes-app#visitNotesFormWorkspace",
      "window": "service-queues-visit-note",
      "privileges": "app:service-queues"
    },
    {
      "name": "queue-patient-search-workspace",
      "component": "@sihsalus/esm-patient-search-app#patientSearchWorkspace2",
      "window": "add-queue-entry",
      "privileges": "app:service-queues"
    },
    {
      "name": "queue-patient-search-add-to-queue-workspace",
      "component": "createQueueEntryWorkspace2",
      "window": "add-queue-entry",
      "privileges": "app:service-queues"
    },
    {
      "name": "queue-patient-search-start-visit-workspace",
      "component": "@sihsalus/esm-patient-chart-app#startVisitWorkspace",
      "window": "add-queue-entry",
      "privileges": "app:service-queues"
    },
    {
      "name": "service-queues-service-form",
      "component": "addNewQueueWorkspace",
      "window": "add-queue",
      "privileges": "app:service-queues"
    },
    {
      "name": "service-queues-room-workspace",
      "component": "addNewQueueServiceRoomWorkspace2",
      "window": "add-queue-room",
      "privileges": "app:service-queues"
    }
  ],
  "workspaceWindows2": [
    {
      "name": "add-queue-entry",
      "group": "service-queues"
    },
    {
      "name": "add-queue",
      "group": "service-queues"
    },
    {
      "name": "add-queue-room",
      "group": "service-queues"
    },
    {
      "name": "service-queues-patient-vitals",
      "group": "service-queues"
    },
    {
      "name": "service-queues-visit-note",
      "group": "service-queues"
    }
  ],
  "workspaceGroups2": [
    {
      "name": "service-queues",
      "scopePattern": "/home/service-queues"
    }
  ]
}
