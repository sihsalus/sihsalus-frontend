{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "extensions": [
    {
      "name": "clinical-encounter",
      "slot": "patient-chart-clinical-encounter-slot",
      "component": "inPatientClinicalEncounter",
      "order": 0,
      "online": true,
      "offline": false
    },
    {
      "name": "consulta-externa-dashboard-link",
      "component": "consultaExternaDashboardLink",
      "slot": "patient-chart-dashboard-slot",
      "order": 9,
      "meta": {
        "columns": 1,
        "columnSpan": 1,
        "slot": "patient-chart-consulta-externa-slot",
        "title": "consultaExterna",
        "path": "consulta-externa",
        "icon": "omrs-icon-document",
        "layoutMode": "anchored"
      }
    },
    {
      "name": "consulta-externa-dashboard",
      "slot": "patient-chart-consulta-externa-slot",
      "component": "consultaExternaDashboard",
      "order": 0,
      "online": true,
      "offline": false
    },
    {
      "name": "social-history-dashboard",
      "slot": "patient-chart-social-history-dashboard-slot",
      "component": "inPatientClinicalEncounter",
      "order": 0,
      "online": true,
      "offline": false
    },
    {
      "name": "social-history-dashboard-link",
      "component": "socialHistoryDashboardLink",
      "slot": "patient-chart-dashboard-slot",
      "order": 10,
      "meta": {
        "columns": 1,
        "columnSpan": 1,
        "slot": "patient-chart-social-history-dashboard-slot",
        "title": "socialHistory",
        "path": "social-history-dashboard",
        "icon": "omrs-icon-sticky-note-add",
        "layoutMode": "anchored"
      }
    }
  ],
  "modals": [
    {
      "name": "condition-delete-confirmation-dialog",
      "component": "conditionFilterDeleteConfirmationDialog"
    }
  ],
  "workspaces": [
    {
      "name": "conditions-filter-form-workspace",
      "component": "conditionsFilterWorkspace",
      "title": "Antecedentes",
      "type": "form"
    },
    {
      "name": "forms-selector-workspace",
      "component": "formsSelectorWorkspace",
      "title": "Selección de Formularios",
      "type": "form"
    }
  ]
}
