{
  "name": "@sihsalus/esm-emergency-app",
  "version": "1.0.0-alpha",
  "description": "Emergency module microfrontend for OpenMRS",
  "browser": "dist/sihsalus-esm-emergency-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "yarn serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage --passWithNoTests",
    "typescript": "node ../../../node_modules/typescript/bin/tsc --noEmit",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/sihsalus/sihsalus-esm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/sihsalus-esm.git"
  },
  "bugs": {
    "url": "https://github.com/sihsalus/sihsalus-esm/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.109.0",
    "@hookform/resolvers": "^3.3.0",
    "@openmrs/esm-utils": "workspace:*",
    "@sihsalus/esm-rbac": "workspace:*",
    "lodash-es": "^4.17.21",
    "react-hook-form": "^7.78.0",
    "swr": "^2.3.6",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "cross-env": "^7.0.3",
    "openmrs": "*",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  }
}
