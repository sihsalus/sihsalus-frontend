{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "pages": [
    {
      "component": "root",
      "routeRegex": "^home($|/.*)",
      "online": true,
      "offline": true
    }
  ],
  "extensions": [
    {
      "name": "home-app-menu-item",
      "slot": "app-menu-item-slot",
      "component": "homeAppMenuItem",
      "privileges": "app:home",
      "order": 0,
      "online": true,
      "offline": true
    },
    {
      "name": "home-nav-menu",
      "slot": "home-sidebar-slot",
      "component": "homeNavMenu",
      "online": true,
      "offline": true
    },
    {
      "name": "global-home-nav-link",
      "slot": "global-nav-menu-slot",
      "component": "globalHomeNavLink",
      "privileges": "app:home",
      "order": -100,
      "online": true,
      "offline": true
    },
    {
      "name": "home-widget-db-link",
      "slot": "homepage-dashboard-slot",
      "component": "homeWidgetDbLink",
      "privileges": "app:home",
      "meta": {
        "name": "home",
        "slot": "home-dashboard-slot",
        "title": ""
      },
      "order": 0,
      "online": true,
      "offline": true
    },
    {
      "name": "page-header",
      "slot": "home-dashboard-slot",
      "component": "homePageHeader"
    },
    {
      "name": "peru-home-actions",
      "slot": "home-dashboard-slot",
      "component": "peruHomeActions",
      "online": true,
      "offline": true
    },
    {
      "name": "metrics-slot",
      "slot": "home-dashboard-slot",
      "component": "metrics",
      "online": true,
      "offline": true
    },
    {
      "name": "home-widget-dashboard",
      "slot": "home-dashboard-slot",
      "component": "homeWidgetDashboard",
      "online": true,
      "offline": true
    }
  ]
}
