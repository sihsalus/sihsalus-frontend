{
  "name": "@sihsalus/esm-psicologia-app",
  "version": "1.0.0-alpha",
  "description": "Módulo de Psicología para el contexto de salud peruano - OpenMRS O3",
  "browser": "dist/sihsalus-esm-psicologia-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "yarn serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage --passWithNoTests",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "sihsalus",
    "psicologia",
    "psychology"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "lodash-es": "^4.17.21"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@carbon/styles": "1.x",
    "@openmrs/esm-framework": "*",
    "@openmrs/esm-patient-common-lib": "*",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-patient-common-lib": "workspace:*",
    "@rspack/cli": "1.7.11",
    "@rspack/core": "1.7.11",
    "openmrs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^19.2.6",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.30.2",
    "sass": "^1.98.0",
    "swr": "^2.4.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  }
}
