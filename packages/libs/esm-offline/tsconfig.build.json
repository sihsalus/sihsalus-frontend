{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "incremental": false,
    "noEmit": false,
    "rootDir": "src",
    "skipLibCheck": true
  },
  "extends": "./tsconfig.json",
  "exclude": ["**/*.test.*", "**/setup-tests.*"]
}
