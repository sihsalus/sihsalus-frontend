{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "fhir2": ">=1.2",
    "webservices.rest": ">=2.2.0",
    "reportingrest": ">=1.15.0",
    "reporting": ">=1.27.0"
  },
  "extensions": [
    {
      "name": "reports-app-menu-item",
      "slot": "app-menu-item-slot",
      "component": "reportsAppMenuItem",
      "privileges": "app:reportes",
      "order": 50
    },
    {
      "name": "run-report",
      "component": "runReport",
      "privileges": "app:reportes"
    }
  ],
  "pages": [
    {
      "component": "root",
      "route": "reports"
    }
  ],
  "modals": [
    {
      "name": "cancel-report-modal",
      "component": "cancelReportModal",
      "privileges": "app:reportes"
    }
  ]
}
