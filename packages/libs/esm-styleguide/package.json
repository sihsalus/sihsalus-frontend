{
  "name": "@openmrs/esm-styleguide",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "description": "OpenMRS Styleguide — vendored fork with local patches",
  "browser": "dist/openmrs-esm-styleguide.js",
  "main": "src/index.ts",
  "source": true,
  "types": "dist/internal.d.ts",
  "exports": {
    ".": {
      "types": "./dist/internal.d.ts",
      "default": "./src/internal.ts"
    },
    "./src/internal": {
      "types": "./dist/internal.d.ts",
      "default": "./src/internal.ts"
    },
    "./dist/openmrs-esm-styleguide.css": {
      "default": "./dist/openmrs-esm-styleguide.css"
    },
    "./styles": {
      "sass": "./dist/_all.scss",
      "default": "./dist/_all.scss"
    },
    "./src/public": {
      "types": "./dist/public.d.ts",
      "default": "./src/public.ts"
    },
    "./src/index": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./src/vars": {
      "sass": "./src/_vars.scss"
    },
    "./mock": {
      "import": "./mock.tsx",
      "require": "./mock-vitest.tsx"
    }
  },
  "scripts": {
    "build": "rspack build -c rspack.config.cjs && tsc -p tsconfig.build.json",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch --passWithNoTests",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests",
    "typescript": "tsc --noEmit && tsc -p tsconfig.build.json",
    "lint": "node ../../tooling/scripts/run-biome.js lint ."
  },
  "dependencies": {
    "@carbon/charts": "^1.27.0",
    "@carbon/react": "^1.92.1",
    "@internationalized/date": "^3.8.0",
    "@openmrs/esm-extensions": "workspace:*",
    "@openmrs/esm-routes": "workspace:*",
    "@react-aria/datepicker": "^3.16.1",
    "@react-aria/utils": "^3.28.2",
    "@react-stately/datepicker": "^3.16.1",
    "d3": "^7.8.0",
    "geopattern": "^1.2.3",
    "lodash-es": "^4.17.21",
    "react-aria-components": "^1.7.1"
  },
  "devDependencies": {
    "@openmrs/esm-api": "workspace:*",
    "@openmrs/esm-config": "workspace:*",
    "@openmrs/esm-emr-api": "workspace:*",
    "@openmrs/esm-error-handling": "workspace:*",
    "@openmrs/esm-globals": "workspace:*",
    "@openmrs/esm-navigation": "workspace:*",
    "@openmrs/esm-react-utils": "workspace:*",
    "@openmrs/esm-state": "workspace:*",
    "@openmrs/esm-translations": "workspace:*",
    "@openmrs/esm-utils": "workspace:*",
    "@rspack/cli": "1.7.11",
    "@rspack/core": "1.7.11",
    "clean-webpack-plugin": "4.0.0",
    "css-loader": "7.1.4",
    "sass-embedded": "1.89.0",
    "sass-loader": "16.0.5",
    "swc-loader": "0.2.7",
    "typescript": "6.0.3",
    "webpack-bundle-analyzer": "4.10.2"
  },
  "peerDependencies": {
    "@openmrs/esm-api": "9.x",
    "@openmrs/esm-config": "9.x",
    "@openmrs/esm-emr-api": "9.x",
    "@openmrs/esm-error-handling": "9.x",
    "@openmrs/esm-extensions": "9.x",
    "@openmrs/esm-globals": "9.x",
    "@openmrs/esm-navigation": "9.x",
    "@openmrs/esm-react-utils": "9.x",
    "@openmrs/esm-routes": "9.x",
    "@openmrs/esm-state": "9.x",
    "@openmrs/esm-translations": "9.x",
    "@openmrs/esm-utils": "9.x",
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "rxjs": "6.x",
    "swr": "2.x"
  }
}
