{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "pages": [
    {
      "component": "root",
      "route": "interconsultas"
    }
  ],
  "extensions": [
    {
      "name": "interconsultas-dashboard",
      "slot": "interconsultas-dashboard-slot",
      "component": "root",
      "privileges": "app:home.interconsultas"
    },
    {
      "name": "interconsultas-dashboard-link",
      "slot": "homepage-dashboard-slot",
      "component": "interconsultasDashboardLink",
      "meta": {
        "name": "interconsultas",
        "slot": "interconsultas-dashboard-slot",
        "title": "Interconsultas"
      },
      "privileges": "app:home.interconsultas",
      "order": 16
    },
    {
      "name": "interconsultas-chart-dashboard-link",
      "component": "interconsultasChartDashboardLink",
      "privileges": "app:hoja.clinica.interconsultas",
      "slot": "patient-chart-dashboard-slot",
      "order": 14,
      "meta": {
        "slot": "patient-chart-interconsultas-slot",
        "columns": 1,
        "title": "Interconsultas",
        "path": "interconsultas",
        "icon": "omrs-icon-referral-order",
        "layoutMode": "anchored"
      }
    },
    {
      "name": "interconsultas-chart-widget",
      "component": "interconsultasChartWidget",
      "privileges": "app:hoja.clinica.interconsultas",
      "slot": "patient-chart-interconsultas-slot",
      "order": 0
    },
    {
      "name": "request-interconsulta-action-button",
      "component": "requestInterconsultaActionButton",
      "privileges": "app:hoja.clinica.interconsultas.editar",
      "slot": "patient-actions-slot",
      "order": 6
    }
  ],
  "modals": [
    {
      "name": "receive-interconsulta-modal",
      "component": "receiveInterconsultaModal",
      "privileges": "app:hoja.clinica.interconsultas.editar"
    },
    {
      "name": "pickup-interconsulta-modal",
      "component": "pickupInterconsultaModal",
      "privileges": "app:hoja.clinica.interconsultas.editar"
    },
    {
      "name": "reject-interconsulta-modal",
      "component": "rejectInterconsultaModal",
      "privileges": "app:hoja.clinica.interconsultas.editar"
    },
    {
      "name": "respond-interconsulta-modal",
      "component": "respondInterconsultaModal",
      "privileges": "app:hoja.clinica.interconsultas.editar"
    },
    {
      "name": "interconsulta-detail-modal",
      "component": "interconsultaDetailModal",
      "privileges": "app:hoja.clinica.interconsultas"
    }
  ],
  "workspaces2": [
    {
      "name": "request-interconsulta-workspace",
      "component": "requestInterconsultaWorkspace",
      "window": "request-interconsulta-window",
      "privileges": "app:hoja.clinica.interconsultas.editar"
    }
  ],
  "workspaceWindows2": [
    {
      "name": "request-interconsulta-window",
      "group": "patient-chart",
      "width": "wider"
    }
  ]
}
