{
  "name": "@sihsalus/esm-openconceptlab-app",
  "version": "1.0.0-alpha",
  "license": "MPL-2.0",
  "description": "Open Concept Lab management frontend module for O3",
  "browser": "dist/openmrs-esm-openconceptlab-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.component.tsx' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "openconceptlab",
    "OCL",
    "medical terminology"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-admin-tools.git"
  },
  "homepage": "https://github.com/openmrs/openmrs-esm-admin-tools#readme",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-admin-tools/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "@sihsalus/esm-rbac": "workspace:*",
    "lodash-es": "^4.17.21",
    "swr": "^2.2.5"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "openmrs": "*",
    "typescript": "6.0.3",
    "vitest": "^4.1.0"
  }
}
