{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "extensions": [
    {
      "name": "tamizajes-home-link",
      "component": "tamizajesHomeLink",
      "slot": "homepage-dashboard-slot",
      "meta": {
        "name": "tamizajes",
        "title": "Tamizajes",
        "slot": "tamizajes-home-slot",
        "path": "/home/tamizajes"
      },
      "privileges": ["app:home.tamizajes", "app:hoja.clinica.tamizajes", "Get Patients"],
      "order": 45
    },
    {
      "name": "tamizajes-home",
      "component": "root",
      "slot": "tamizajes-home-slot",
      "privileges": ["app:home.tamizajes", "app:hoja.clinica.tamizajes", "Get Patients"],
      "order": 0,
      "online": true,
      "offline": false
    },
    {
      "name": "tamizajes-dashboard-link",
      "component": "tamizajesDashboardLink",
      "slot": "patient-chart-dashboard-slot",
      "privileges": "app:hoja.clinica.tamizajes",
      "order": 11,
      "meta": {
        "slot": "patient-chart-tamizajes-dashboard-slot",
        "columns": 1,
        "columnSpan": 1,
        "title": "Tamizajes",
        "path": "tamizajes",
        "icon": "omrs-icon-lab-order",
        "layoutMode": "anchored"
      }
    },
    {
      "name": "tamizajes-dashboard",
      "component": "tamizajesDashboard",
      "slot": "patient-chart-tamizajes-dashboard-slot",
      "privileges": "app:hoja.clinica.tamizajes",
      "order": 0,
      "online": true,
      "offline": false
    }
  ],
  "workspaces2": [
    {
      "name": "tamizajes-patient-search-workspace",
      "component": "@sihsalus/esm-patient-search-app#patientSearchWorkspace2",
      "window": "tamizajes-patient-search",
      "privileges": ["app:home.tamizajes", "app:hoja.clinica.tamizajes", "Get Patients"]
    }
  ],
  "workspaceWindows2": [
    {
      "name": "tamizajes-patient-search",
      "group": "tamizajes"
    }
  ],
  "workspaceGroups2": [
    {
      "name": "tamizajes",
      "scopePattern": "/home/tamizajes",
      "overlay": true
    }
  ]
}
