{
  "name": "@sihsalus/esm-openmrs-livekit-app",
  "version": "1.0.0-alpha",
  "description": "OpenMRS LiveKit clinical translation review frontend module",
  "browser": "dist/openmrs-esm-openmrs-livekit-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "node ../../tooling/scripts/run-biome.js lint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "livekit",
    "clinical-ai",
    "local-ai",
    "translation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "react": "18.x",
    "react-dom": "18.x",
    "react-i18next": "16.x"
  },
  "devDependencies": {
    "openmrs": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "^4.1.7"
  }
}
