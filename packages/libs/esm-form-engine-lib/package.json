{
  "name": "@sihsalus/esm-form-engine-lib",
  "version": "4.1.0",
  "description": "React Form Engine for O3",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.*",
    "!src/setup-tests.ts",
    "!src/utils/test-utils.ts",
    "!src/zscore-tests",
    "README.md",
    "LICENSE.txt",
    "readme"
  ],
  "license": "MIT",
  "homepage": "https://github.com/openmrs/openmrs-esm-form-engine-lib#readme",
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "lint": "node ../../tooling/scripts/run-biome.js lint src",
    "test": "vitest run --passWithNoTests",
    "typescript": "tsc",
    "build": "rimraf dist && swc --strip-leading-paths --copy-files --ignore '**/*.test.*' --ignore '**/setup-tests.*' --ignore '**/test-utils.*' src -d dist && tsc --project tsconfig.build.json",
    "extract-translations": "i18next 'src/**/*.{ts,tsx}' '!src/**/*.test.{ts,tsx}' '!src/**/*.spec.{ts,tsx}' --config ../../tooling/scripts/i18next-parser.config.js"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0",
    "@openmrs/esm-utils": "workspace:*",
    "classnames": "^2.5.1",
    "jsep": "^1.4.0",
    "lodash-es": "^4.17.21",
    "react-error-boundary": "^4.0.13",
    "react-hook-form": "^7.52.0",
    "react-markdown": "^9.0.1",
    "react-waypoint": "^10.3.0",
    "react-webcam": "^7.2.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "workspace:*",
    "@openmrs/esm-styleguide": "workspace:*",
    "@swc/cli": "0.8.1",
    "@swc/core": "^1.5.7",
    "@types/lodash": "^4.17.4",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.2",
    "dayjs": "^1.11.11",
    "husky": "^8.0.3",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "lint-staged": "^15.2.2",
    "openmrs": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^5.0.0",
    "sass": "^1.77.2",
    "swr": "^2.2.5",
    "turbo": "^2.9.18",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.10.3"
}
