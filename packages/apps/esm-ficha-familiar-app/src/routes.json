{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "extensions": [
    {
      "name": "family-history",
      "slot": "patient-chart-family-history-slot",
      "component": "familyHistory",
      "privileges": "app:clinical.chart.family",
      "order": 0,
      "online": true,
      "offline": false
    },
    {
      "name": "other-relationships",
      "slot": "patient-chart-family-history-slot",
      "component": "otherRelationships",
      "privileges": "app:clinical.chart.family",
      "order": 1,
      "online": true,
      "offline": false
    },
    {
      "name": "relationships",
      "slot": "patient-chart-relationships-slot",
      "component": "relationships",
      "privileges": "app:clinical.chart.family",
      "order": 0,
      "online": true,
      "offline": false
    },
    {
      "name": "relationships-link",
      "component": "relationshipsLink",
      "privileges": "app:clinical.chart.family",
      "slot": "patient-chart-dashboard-slot",
      "order": 11,
      "meta": {
        "columns": 1,
        "columnSpan": 1,
        "slot": "patient-chart-relationships-slot",
        "path": "relationships",
        "layoutMode": "anchored"
      }
    }
  ],
  "modals": [
    {
      "name": "birth-date-calculator",
      "component": "birthDateCalculator",
      "privileges": "app:clinical.chart.family.edit"
    },
    {
      "name": "relationship-delete-confirm-dialog",
      "component": "relationshipDeleteConfirmDialog",
      "privileges": "app:clinical.chart.family.edit"
    }
  ],
  "workspaces": [
    {
      "name": "family-relationship-form",
      "component": "familyRelationshipForm",
      "privileges": "app:clinical.chart.family.edit",
      "title": "Formulario de relación familiar",
      "type": "form"
    },
    {
      "name": "other-relationship-form",
      "component": "otherRelationshipsForm",
      "privileges": "app:clinical.chart.family.edit",
      "title": "Formulario de relación no familiar",
      "type": "form"
    },
    {
      "name": "relationship-update-form",
      "component": "relationshipUpdateForm",
      "privileges": "app:clinical.chart.family.edit",
      "title": "Editar relación",
      "type": "form"
    },
    {
      "name": "contact-list-form",
      "component": "contactListForm",
      "privileges": "app:clinical.chart.family.edit",
      "title": "Formulario de contactos sexuales",
      "type": "form"
    }
  ],
  "workspaces2": [
    {
      "name": "family-relationship-form",
      "component": "familyRelationshipForm",
      "window": "patient-chart-family-record-forms",
      "privileges": "app:clinical.chart.family.edit"
    },
    {
      "name": "other-relationship-form",
      "component": "otherRelationshipsForm",
      "window": "patient-chart-family-record-forms",
      "privileges": "app:clinical.chart.family.edit"
    },
    {
      "name": "relationship-update-form",
      "component": "relationshipUpdateForm",
      "window": "patient-chart-family-record-forms",
      "privileges": "app:clinical.chart.family.edit"
    },
    {
      "name": "contact-list-form",
      "component": "contactListForm",
      "window": "patient-chart-family-record-forms",
      "privileges": "app:clinical.chart.family.edit"
    }
  ],
  "workspaceWindows2": [
    {
      "name": "patient-chart-family-record-forms",
      "group": "patient-chart",
      "order": 11,
      "width": "wider",
      "canMaximize": true
    }
  ]
}
