{
  "extends": "../../tooling/tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "target": "es2015",
    "strict": true,
    "strictFunctionTypes": false,
    "paths": {
      "@hooks/*": ["./src/hooks/*"],
      "@types": ["./src/types"],
      "@tools/*": ["./tools/*"],
      "@constants": ["./src/constants"],
      "@resources/*": ["./src/resources/*"],
      "test-utils": ["../../test-utils/index.tsx"],
      "test-utils/*": ["../../test-utils/*"],
      "@openmrs/*": ["../../../node_modules/@openmrs/*"]
    }
  },
  "include": ["src/**/*", "../../tools/setup-tests.ts"],
  "exclude": ["src/**/*.test.tsx", "src/**/*.test.ts", "src/**/*.test.jsx", "src/**/*.test.js"],
  "types": ["@testing-library/jest-dom", "lodash"]
}
